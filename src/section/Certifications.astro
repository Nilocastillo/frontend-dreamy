---
import type { Premio } from "@/interface/home";
import type { Lang } from "@/lib/i18n";
import { useTranslations } from "@/i18n/ui";
import { getImageAlt, getImageUrl } from "@/lib/helpers";

interface Props {
  data?: Premio[];
  lang: Lang;
}

const { data, lang } = Astro.props;
const t = useTranslations(lang);

const premios: Premio[] = Array.isArray(data) ? data : [];

if (premios.length === 0) return;

// duplicamos el array para loop infinito
const sliderData = [...premios, ...premios];
---

<section class="slider-container mx-auto max-w-8xl px-6 py-16">
  <div class="text-center mb-10">
    <h2
      class="text-2xl md:text-3xl font-bold text-gray-900 mb-6 relative inline-block"
    >
      <span class="relative z-10">{t("section.premiosCertificaciones")}</span>
      <span
        class="absolute bottom-0 left-1/2 -translate-x-1/2 w-24 h-3 bg-secondary/30 -z-0 rounded-full blur-sm"
      ></span>
    </h2>
    <div class="flex items-center justify-center gap-3 mt-4">
      <div class="h-[1px] w-16 bg-gradient-to-r from-transparent to-secondary">
      </div>
      <div class="w-12 h-1.5 bg-secondary rounded-full relative">
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 bg-white rounded-full"
        >
        </div>
      </div>
      <div class="h-[1px] w-16 bg-gradient-to-l from-transparent to-secondary">
      </div>
    </div>
  </div>
  <div class="slider-track w-full">
    {
      sliderData.map((cert) => {
        const imageUrl = getImageUrl(cert.logo);

        return (
          <div class="slide" title={cert.description}>
            {imageUrl !== "/og-default.jpg" && (
              <img
                src={imageUrl}
                alt={getImageAlt(cert.logo, cert.description)}
                loading="lazy"
                width={cert.logo?.width}
                height={cert.logo?.height}
                decoding="async"
              />
            )}
          </div>
        );
      })
    }
  </div>
</section>

<style>
  .slider-container {
    overflow: hidden;
    position: relative;
    /* Efecto de desenfoque a los bordes con mask-image */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 15%,
      black 85%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      black 15%,
      black 85%,
      transparent
    );
  }

  .slider-track {
    display: flex;
    align-items: center;
    gap: 6rem; /* Espacio entre logos */
    width: 100%;
    /* Animación CSS infinita */
    animation: scroll 25s linear infinite;
  }

  .slider-container:hover .slider-track {
    animation-play-state: paused;
  }

  .slide {
    flex-shrink: 0;
    min-width: 120px;
    max-width: 200px;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 1rem;
    border-radius: 12px;
    border: 1px solid transparent;
    transition: all 0.3s ease;
  }

  .slide:hover {
    transform: translateY(-8px);
    border-color: #4a5d4e;
    background: white;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .slide img {
    max-width: 100%;
    max-height: 120px; /* Alto máximo para los logos */
    object-fit: contain;
    /* Opcional: logos en grisáceo que se colorean al pasar el mouse */
    opacity: 0.7;
    transition: all 0.3s ease;
  }

  .slide:hover img {
    opacity: 1;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      /* Se traslada la mitad exacta de todo el ancho + la mitad del gap para un loop perfecto */
      transform: translateX(calc(-50% - 1.5rem));
    }
  }
</style>
