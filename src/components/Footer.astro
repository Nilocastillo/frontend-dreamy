---
import type { Footer as FooterType } from "@/interface/global";
import type { Lang } from "@/lib/i18n";
import { getImageAlt, getImageUrl } from "@/lib/helpers";
import { rewriteUrl } from "@/lib/utils";

interface Props {
  data?: FooterType;
  lang: Lang;
}

const { data, lang } = Astro.props;
---

<footer class="bg-foreground text-white pb-8">
  {/* Slider de Certificaciones */}
  {
    data?.certificaciones &&
      Array.isArray(data.certificaciones) &&
      data.certificaciones.length > 0 &&
      data.certificaciones[0]?.premios && (
        <div class="bg-white py-10 -mt-8 mb-12">
          <div class="max-w-8xl mx-auto px-6">
            <div class="text-center mb-8">
              <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6 relative inline-block">
                <span class="relative z-10">We Are Part Of</span>
                <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-24 h-3 bg-secondary/30 -z-0 rounded-full blur-sm" />
              </h2>
              <div class="flex items-center justify-center gap-3 mt-4">
                <div class="h-[1px] w-16 bg-gradient-to-r from-transparent to-secondary" />
                <div class="w-12 h-1.5 bg-secondary rounded-full relative">
                  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 bg-white rounded-full" />
                </div>
                <div class="h-[1px] w-16 bg-gradient-to-l from-transparent to-secondary" />
              </div>
            </div>
            <div class="flex flex-wrap justify-center items-center gap-6 md:gap-8">
              {data.certificaciones[0].premios.map((cert) => {
                const imageUrl = getImageUrl(cert.logo);
                return (
                  imageUrl !== "/og-default.jpg" && (
                    <div class="group w-32 h-24 md:w-40 md:h-28 flex items-center justify-center bg-white rounded-sm shadow-md hover:shadow-xl hover:-translate-y-2 transition-all duration-300 overflow-hidden border border-gray-100">
                      <img
                        src={imageUrl}
                        alt={getImageAlt(
                          cert.logo,
                          cert.description || "Certificación",
                        )}
                        class="max-w-full max-h-full w-auto h-auto object-contain p-2"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  )
                );
              })}
            </div>
          </div>
        </div>
      )
  }

  <div class="container mx-auto px-4 pt-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8 lg:gap-12">
      {/* Logo y descripción - centrado en tablet/móvil */}
      <div class="lg:col-span-2 md:col-span-2">
        {
          data?.logo?.imagen?.url && (
            <img
              src={getImageUrl(data.logo.imagen)}
              alt={getImageAlt(data.logo.imagen, data.logo.label)}
              class="h-20 w-auto mb-8 mx-auto md:mx-0"
              decoding="async"
            />
          )
        }
        {
          data?.content && (
            <p class="text-gray-400 text-sm leading-relaxed max-w-sm mx-auto md:mx-0">
              {data.content}
            </p>
          )
        }
      </div>

      {/* Destinations */}
      <div>
        {
          data?.destination?.titulo && (
            <h3 class="text-lg font-semibold mb-4">
              {data.destination.titulo}
            </h3>
          )
        }
        {
          data?.destination?.link && data.destination.link.length > 0 && (
            <ul class="space-y-2">
              {data.destination.link.map((link) => (
                <li>
                  <a
                    href={rewriteUrl(link.url, lang)}
                    class="text-gray-400 hover:text-white transition-colors text-sm"
                    target={link.isExternal ? "_blank" : "_self"}
                    rel={link.isExternal ? "noopener noreferrer" : ""}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>

      {/* Dreamy About */}
      <div>
        {
          data?.dreamyAbout?.titulo && (
            <h3 class="text-lg font-semibold mb-4">
              {data.dreamyAbout.titulo}
            </h3>
          )
        }
        {
          data?.dreamyAbout?.link && data.dreamyAbout.link.length > 0 && (
            <ul class="space-y-2">
              {data.dreamyAbout.link.map((link) => (
                <li>
                  <a
                    href={rewriteUrl(link.url, lang)}
                    class="text-gray-400 hover:text-white transition-colors text-sm"
                    target={link.isExternal ? "_blank" : "_self"}
                    rel={link.isExternal ? "noopener noreferrer" : ""}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>

      {/* Contact */}
      <div>
        {
          data?.contact?.titulo && (
            <h3 class="text-lg font-semibold mb-4">{data.contact.titulo}</h3>
          )
        }
        {
          data?.contact?.link && data.contact.link.length > 0 && (
            <ul class="space-y-4">
              {data.contact.link.map((link, index) => (
                <li>
                  {index < 5 ? (
                    <a
                      href={rewriteUrl(link.url, lang)}
                      class="text-gray-400 hover:text-white transition-colors text-sm flex items-start gap-2"
                      target={link.isExternal ? "_blank" : "_self"}
                      rel={link.isExternal ? "noopener noreferrer" : ""}
                    >
                      <span class="mt-0.5 shrink-0">
                        {/* Email */}
                        {index === 0 && (
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="size-6"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                            />
                          </svg>
                        )}
                        {/* WhatsApp */}
                        {index === 1 && (
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="size-6"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                          </svg>
                        )}
                        {/* Phone */}
                        {index === 2 && (
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="size-6"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            />
                          </svg>
                        )}
                        {/* Location (index 3 and 4) */}
                        {(index === 3 || index === 4) && (
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="size-6"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                            />
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                            />
                          </svg>
                        )}
                      </span>
                      <span>{link.label}</span>
                    </a>
                  ) : (
                    <span class="text-gray-400 text-sm">{link.label}</span>
                  )}
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </div>

    <div class="border-t border-gray-800 mt-12 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        {
          data?.socialTitle && (
            <h4 class="text-sm font-medium">{data.socialTitle}</h4>
          )
        }
        {
          data?.socialLogo && data.socialLogo.length > 0 && (
            <div class="flex gap-4">
              {data.socialLogo.map((social) => (
                <a
                  href={social.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Síguenos en ${social.label || "red social"}`}
                  class="group border border-primary/50 p-4 flex items-center justify-center rounded-full hover:scale-110 hover:rotate-12 transition-all duration-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                >
                  {social.imagen?.url && (
                    <img
                      src={getImageUrl(social.imagen)}
                      alt=""
                      aria-hidden="true"
                      class="h-8 w-auto"
                      decoding="async"
                    />
                  )}
                </a>
              ))}
            </div>
          )
        }
      </div>
    </div>
  </div>
</footer>
