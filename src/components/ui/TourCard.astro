---
import type { Tour } from "@/interface/tours";
import type { Lang } from "@/lib/i18n";
import { useTranslations } from "@/i18n/ui";
import BadgeIcon from "@/components/ui/BadgeIcon.astro";

interface Props {
  tour: Tour;
  lang: Lang;
}

const { tour, lang } = Astro.props;

if (!tour) return null;

const t = useTranslations(lang);

const strapiUrl = import.meta.env.VITE_STRAPI_URL?.replace(/\/$/, "");

const imgObj = Array.isArray(tour.imagenDestacada)
  ? tour.imagenDestacada[0]
  : tour.imagenDestacada;

const mainImage = imgObj?.url ? `${strapiUrl}${imgObj.url}` : null;
const primaryCategory = tour.categories?.[0]?.nombre;
---

<article
  class="group relative flex h-full flex-col overflow-hidden rounded-sm border border-slate-200/80 bg-white transition-all duration-500 hover:-translate-y-1 hover:border-primary/15"
>
  {/* Image Container */}
  <a
    href={`/${lang}/${tour.slug}`}
    tabindex="-1"
    aria-hidden="true"
    class="relative block w-full shrink-0 overflow-hidden border-b border-slate-200/70 aspect-[4/3]"
  >
    {
      primaryCategory && (
        <div class="absolute top-4 left-4 z-20 rounded-xs bg-secondary backdrop-blur-sm px-3 py-1.5 shadow-[0_4px_12px_rgb(0,0,0,0.08)] transition-transform duration-300 group-hover:scale-105">
          <p class="text-[0.65rem] font-bold uppercase tracking-[0.16em] text-white">
            {primaryCategory}
          </p>
        </div>
      )
    }
    {
      mainImage ? (
        <img
          src={mainImage}
          alt={imgObj?.alternativeText ?? tour.titulo}
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.035]"
          loading="lazy"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-slate-100 text-sm font-medium text-slate-400">
          No Image
        </div>
      )
    }
    <div
      class="absolute inset-0 bg-linear-to-t from-slate-950/30 via-slate-950/5 to-transparent opacity-60 transition-opacity duration-300 group-hover:opacity-70"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-linear-to-t from-black/18 via-black/0 to-transparent"
    >
    </div>
  </a>

  {/* Content Container */}
  <div
    class="relative z-10 flex grow flex-col bg-white px-5 py-5 md:px-6 md:py-6"
  >
    <h3
      class="mb-3 line-clamp-2 text-[1.26rem] font-semibold leading-[1.15] tracking-[-0.02em] text-slate-950 transition-colors duration-300 group-hover:text-secondary md:text-[1.42rem]"
    >
      <a href={`/${lang}/${tour.slug}`} class="focus:outline-hidden">
        {tour.titulo}
      </a>
    </h3>

    {
      tour.content && (
        <p class="mb-5 text-[0.85rem] text-slate-600 line-clamp-2 leading-relaxed">
          {tour.content}
        </p>
      )
    }

    {/* Badges paralelos en Flex - Texto Multilínea */}
    {
      tour.badge && tour.badge.length > 0 && (
        <div class="mb-5 mt-auto flex w-full items-start justify-between gap-1.5 border-t  border-b border-slate-200 pt-4 pb-4">
          {tour.badge.slice(-3).map((b) => (
            <div class="flex flex-1 items-center gap-2" title={b.content}>
              <div class="flex-shrink-0 w-8 h-8 sm:w-9 sm:h-9 rounded-md bg-gradient-to-br from-primary/10 to-secondary/5 flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
                <BadgeIcon title={b.titulo} content={b.content} className="h-4 w-4 sm:h-5 sm:w-5 text-gray-700 transition-colors duration-300 group-hover:text-secondary" />
              </div>
              <div class="min-w-0">
                <p class="text-[0.78rem] font-semibold text-slate-700 leading-[1.1] break-words line-clamp-2">
                  {b.content}
                </p>
              </div>
            </div>
          ))}
        </div>
      )
    }
    <div class="mt-auto pt-1">
      <a
        href={`/${lang}/${tour.slug}`}
        class="group/btn inline-flex w-full items-center justify-between gap-2 rounded-sm border border-primary/15 bg-primary px-4 py-2 text-sm font-semibold text-white transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/30 hover:bg-primary/95 active:scale-[0.995]"
      >
        {t("tour.verItinerario")}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 transition-transform duration-300 group-hover/btn:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
    </div>
  </div>
</article>
