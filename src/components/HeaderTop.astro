---
import type { HeaderTop as HeaderTopType } from "@/interface/global";
import Button from "@/components/ui/button.astro";
import { LanguageSwitcher } from "@/components/LanguageSwitcher";
import type { Lang } from "@/lib/i18n";
import { localizePath } from "@/lib/i18n";
import { rewriteUrl } from "@/lib/utils";
import { getImageUrl } from "@/lib/helpers";

interface Props {
  data?: HeaderTopType;
  lang: Lang;
}

const { data, lang } = Astro.props;
if (!data) return;

/**
 * El logo SIEMPRE apunta al home localizado.
 * No usamos data.logo.url de Strapi porque puede ser una URL absoluta
 * (empieza con "http") que rewriteUrl no localiza por diseño.
 * localizePath garantiza: en → "/", es → "/es", pt → "/pt"
 */
const logoUrl = localizePath("/", lang);

// Función helper para links / botones
const getLinkProps = (
  link: (typeof data.headerLink)[number] | (typeof data.button)[number],
) => {
  const isExternal = link.isExternal;
  return {
    target: isExternal ? "_blank" : "_self",
    rel: isExternal ? "noopener noreferrer" : undefined,
  };
};
---

<div class="hidden lg:block w-full bg-background text-foreground pb-4">
  <!-- Bloque superior: links a la izquierda, logo a la derecha -->
  <div class="flex max-w-8xl justify-between items-center mx-auto px-4">
    <!-- Logo -->
    <div class="group">
      <a
        href={logoUrl}
        target={data.logo.isExternal ? "_blank" : "_self"}
        rel={data.logo.isExternal ? "noopener noreferrer" : undefined}
      >
        {
          data.logo.imagen && (
            <img
              src={getImageUrl(data.logo.imagen)}
              alt={data.logo.imagen.alternativeText ?? data.logo.label}
              width={data.logo.imagen.width}
              height={data.logo.imagen.height}
              class="h-16 w-auto group-hover:scale-105 duration-300 transition-transform"
            />
          )
        }
      </a>
    </div>
    <div class="flex flex-col items-end">
      <!-- Links a la izquierda -->
      <nav
        class="hidden lg:flex flex-wrap justify-center p-4 divide-x-1 divide-neutral-400"
      >
        {
          data.headerLink.map((link) => {
            const { target, rel } = getLinkProps(link);
            return (
              <a
                href={rewriteUrl(link.url, lang)}
                target={target}
                rel={rel}
                class="px-4 text-muted-foreground hover:text-primary transition-colors duration-200 cursor-pointer"
              >
                {link.label}
              </a>
            );
          })
        }
      </nav>
      <div
        class="mt-2 flex flex-wrap gap-2 justify-center items-center md:justify-start"
      >
        <div class="hidden lg:flex gap-2">
          {
            data.button.map((btn) => (
              <Button
                label={btn.label}
                href={rewriteUrl(btn.url, lang)}
                type={btn.type}
                isExternal={btn.isExternal}
              />
            ))
          }
        </div>
        <LanguageSwitcher currentLang={lang} client:load />
      </div>
    </div>
  </div>
</div>
