---
interface Props {
  phoneNumber?: string;
  message?: string;
  label?: string;
}

const {
  phoneNumber = "51969787221",
  message = "Hola, quisiera más información sobre sus tours.",
  label = "Escribinos por WhatsApp",
} = Astro.props;

const cleanPhone = phoneNumber.replace(/\D/g, "");
const href = `https://wa.me/${cleanPhone}${message ? `?text=${encodeURIComponent(message)}` : ""}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={label}
  title={label}
  class="group fixed bottom-4 right-4 z-50 inline-flex items-center gap-2 rounded-full bg-[#25D366] px-4 py-3 text-white shadow-lg shadow-green-950/20 ring-1 ring-white/20 transition-all duration-300 hover:-translate-y-0.5 hover:scale-[1.02] hover:bg-[#20c35a] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#25D366] focus-visible:ring-offset-2 focus-visible:ring-offset-background md:bottom-6 md:right-6"
>
  <span class="flex size-10 items-center justify-center rounded-full bg-white/15 transition-transform duration-300 group-hover:rotate-6">
    <svg
      viewBox="0 0 24 24"
      aria-hidden="true"
      class="size-5 fill-current"
      focusable="false"
    >
      <path d="M19.11 4.93A10.85 10.85 0 0 0 12.01 2C6.1 2 1.29 6.81 1.29 12.71c0 1.9.5 3.76 1.44 5.41L1 22l3.99-1.66a10.72 10.72 0 0 0 5.04 1.29h.01c5.9 0 10.7-4.81 10.7-10.71 0-2.86-1.12-5.55-3.13-7.99Zm-7.1 16.47h-.01a8.95 8.95 0 0 1-4.57-1.25l-.33-.2-2.36.98.82-2.28-.22-.37a8.96 8.96 0 0 1-1.37-4.78c0-4.95 4.03-8.98 8.99-8.98a8.94 8.94 0 0 1 6.36 2.63 8.93 8.93 0 0 1 2.62 6.35c0 4.96-4.03 8.9-8.94 8.9Zm4.93-6.44c-.27-.13-1.58-.78-1.82-.87-.24-.09-.42-.13-.6.13-.18.27-.68.87-.83 1.05-.15.18-.3.2-.57.07-.27-.13-1.14-.42-2.18-1.35-.81-.72-1.36-1.6-1.52-1.87-.16-.27-.02-.42.12-.56.12-.12.27-.3.4-.45.13-.15.18-.27.27-.45.09-.18.04-.33-.02-.47-.07-.13-.6-1.44-.82-1.98-.22-.54-.44-.47-.6-.48h-.5c-.18 0-.47.07-.72.33-.24.27-.92.9-.92 2.2 0 1.29.94 2.55 1.07 2.72.13.18 1.85 2.82 4.47 3.95.62.27 1.1.43 1.47.55.62.2 1.17.17 1.61.1.49-.08 1.58-.64 1.8-1.25.22-.6.22-1.12.15-1.25-.07-.13-.24-.2-.51-.33Z" />
    </svg>
  </span>

  <span class="hidden pr-1 text-sm font-semibold tracking-wide sm:inline">
    WhatsApp
  </span>
</a>
