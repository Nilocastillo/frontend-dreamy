---
import type { Tour, Badge } from "@/interface/tours";
import type { Lang } from "@/lib/i18n";
import BadgeIcon from "@/components/ui/BadgeIcon.astro";

interface Props {
  tour: Tour;
  lang: Lang;
  badges?: Badge[];
}

const { tour, badges } = Astro.props;
if (!tour) return;

const strapiUrl = import.meta.env.VITE_STRAPI_URL?.replace(/\/$/, "");

// Extract array of image URLs
const images = Array.isArray(tour.imagenDestacada)
  ? tour.imagenDestacada
      .map((img) => (img?.url ? `${strapiUrl}${img.url}` : null))
      .filter((url): url is string => Boolean(url))
  : tour.imagenDestacada?.url
    ? [`${strapiUrl}${tour.imagenDestacada.url}`]
    : [];

if (images.length === 0) images.push("/og-default.jpg");

const mainImage = images[0];
const subImage1 = images[1] || mainImage;
const subImage2 = images[2] || mainImage;
const showGalleryButton = images.length > 3;

const categoryName = tour.categories?.[0]?.nombre;
const hasBadges = badges && badges.length > 0;
---

<div class="tour-hero-container w-full pt-4 pb-8 relative">
  {/* DESKTOP GRID (Hidden on mobile) */}
  <div
    class="hidden md:grid grid-cols-4 grid-rows-2 gap-3 lg:gap-4 mb-8 lg:mb-12 h-[350px] md:h-[450px] lg:h-[500px]"
  >
    {/* Left Large Image - spans 2 columns and 2 rows */}
    <div
      class="col-span-2 row-span-2 rounded-sm overflow-hidden relative group cursor-pointer shadow-sm"
    >
      <img
        src={mainImage}
        alt={tour.titulo}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
        loading="eager"
        fetchpriority="high"
      />
      <div
        class="absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors duration-500"
      >
      </div>
    </div>

    {/* Image 2 - spans 1 column, 2 rows (positions 2 and 3) */}
    <div
      class="col-span-1 row-span-2 rounded-sm overflow-hidden relative group cursor-pointer shadow-sm"
    >
      <img
        src={subImage1}
        alt={`${tour.titulo} 1`}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
        loading="eager"
      />
      <div
        class="absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors duration-500"
      >
      </div>
    </div>

    {/* Image 3 - spans 1 column, 2 rows (positions 4 and 5) */}
    <div
      class="col-span-1 row-span-2 rounded-sm overflow-hidden relative group cursor-pointer shadow-sm"
    >
      <img
        src={subImage2}
        alt={`${tour.titulo} 2`}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
        loading="eager"
      />
      <div
        class="absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors duration-500"
      >
      </div>
    </div>
  </div>

  {/* MOBILE SLIDER (Hidden on desktop) */}
  <div class="md:hidden w-[100vw] relative left-1/2 -ml-[50vw] mb-6">
    <div
      class="flex overflow-x-auto snap-x snap-mandatory gap-3 px-4 pb-4 hide-scrollbar"
    >
      {
        images.slice(0, 3).map((img, i) => (
          <div class="w-[85vw] h-[320px] shrink-0 snap-center rounded-sm overflow-hidden relative shadow-sm">
            <img
              src={img}
              alt={i === 0 ? tour.titulo : `${tour.titulo} - Imagen ${i + 1}`}
              class="w-full h-full object-cover"
              width="320"
              height="320"
            />
            {i === 2 && showGalleryButton && (
              <button
                class="absolute inset-0 bg-black/40 flex items-center justify-center backdrop-blur-[2px]"
                aria-label={`Ver ${images.length} fotos de ${tour.titulo}`}
              >
                <span class="text-white font-bold text-lg border-2 border-white/50 px-6 py-2 rounded-full">
                  + {images.length - 2}
                </span>
              </button>
            )}
          </div>
        ))
      }
    </div>
  </div>

  {/* TOUR INFO: Title + Description (left) | Badges Card (right) */}
  <div class="w-full items-center animate-fade-in-up mt-8 lg:mt-12">
    <div
      class={`flex items-center flex-col ${hasBadges ? "lg:flex-row" : ""} gap-8 lg:gap-12`}
    >
      {/* Left Column — Title & Description */}
      <div class={`${hasBadges ? "lg:flex-1" : "w-full"}`}>
        {
          categoryName && (
            <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-secondary mb-4">
              {categoryName}
            </span>
          )
        }
        <h1
          class="text-3xl md:text-4xl lg:text-[42px] font-extrabold text-gray-900 dark:text-white tracking-tight leading-[1.15] mb-5 md:mb-6"
        >
          {tour.titulo}
        </h1>
        <p
          class="text-base md:text-[1.05rem] text-gray-600 dark:text-gray-400 leading-relaxed"
        >
          {tour.content}
        </p>
      </div>

      {/* Right Column — Badges Card + CTAs */}
      {
        hasBadges && (
          <div class="lg:w-[380px] xl:w-[420px] shrink-0">
            <div class="rounded-lg border border-gray-200/80 bg-white p-1 shadow-sm">
              {/* Badges Grid */}
              <div class="grid grid-cols-2 rounded-md overflow-hidden divide-x divide-y divide-gray-100 bg-gray-50/50">
                {badges.map((badge, index) => {
                  return (
                    <div
                      class="flex items-center gap-3 p-4 bg-white hover:bg-gray-50 transition-all duration-300 group"
                      style={`animation: badge-fade-in 0.5s ease-out ${index * 0.1}s both;`}
                    >
                      <div class="flex-shrink-0 w-10 h-10 rounded-md bg-gradient-to-br from-primary/10 to-secondary/5 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                        <BadgeIcon title={badge.titulo} content={badge.content} className="w-5 h-5 text-gray-700 group-hover:text-secondary transition-colors duration-300" />
                      </div>
                      <div class="flex flex-col min-w-0">
                        <span class="text-[0.6rem] lg:text-[0.65rem] font-semibold uppercase tracking-wider text-gray-400">
                          {badge.titulo}
                        </span>
                        <span class="text-sm md:text-base font-medium text-gray-900 leading-tight group-hover:text-primary transition-colors">
                          {badge.content}
                        </span>
                      </div>
                    </div>
                  );
                })}
              </div>

              {/* CTA Buttons */}
              <div class="grid grid-cols-2 gap-3 p-4">
                <a
                  href="#tour-contact-form"
                  class="hero-cta-book flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-white py-3 rounded-sm font-bold text-sm uppercase tracking-wider transition-all duration-300 hover:shadow-lg hover:shadow-primary/25 hover:-translate-y-0.5 active:scale-[0.98]"
                >
                  Reservar en línea
                </a>
                <a
                  href="https://wa.me/51999999999"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center justify-center gap-2 border-2 border-secondary text-secondary hover:bg-secondary hover:text-white py-3 rounded-sm font-bold text-sm uppercase tracking-wider transition-all duration-300 hover:-translate-y-0.5 active:scale-[0.98]"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                  </svg>
                  Consulte ahora
                </a>
              </div>

              {/* Help Text */}
              <div class="px-4 pb-4 text-center">
                <p class="text-xs text-gray-400 leading-relaxed">
                  ¡Estamos aquí para ayudarte! Ponte en contacto a través de
                  <a href="https://wa.me/51999999999" target="_blank" rel="noopener noreferrer" class="font-bold text-[#25D366] hover:underline"> WhatsApp</a> o
                  <a href="#tour-contact-form" class="font-bold text-primary hover:underline"> en línea</a>: es rápido y fácil.
                </p>
              </div>
            </div>
          </div>
        )
      }
    </div>
  </div>
</div>

<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .hide-scrollbar {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }

  .animate-fade-in-up {
    animation: tour-fade-up 0.7s ease-out both;
  }

  @keyframes tour-fade-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes badge-fade-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .tour-specs-card {
    border-left: 3px solid var(--color-secondary, #c17a2f);
  }
</style>

<script>
  document.addEventListener("click", (e) => {
    const link = (e.target as HTMLElement).closest('a[href="#tour-contact-form"]');
    if (!link) return;
    e.preventDefault();
    const isMobile = window.innerWidth < 1024;
    const targetId = isMobile ? "tour-contact-form-mobile" : "tour-contact-form";
    const target = document.getElementById(targetId);
    if (target) {
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  });
</script>
