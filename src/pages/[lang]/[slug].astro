---
import TourLayout from "@/layouts/TourLayout.astro";
import PageLayout from "@/layouts/PageLayout.astro";
import PageContent from "@/components/PageContent.astro";
import Layout from "@/layouts/main.astro";
import fetchApi from "@/lib/strapi";
import { dedupeLocalizedDocuments } from "@/lib/utils";
import type { Tour } from "@/interface/tours";
import type { Page } from "@/interface/page";
import { LANGS, DEFAULT_LANG, isValidLang } from "@/lib/i18n";
import type { Lang } from "@/lib/i18n";
import type { SEOProps } from "@/components/SEO.astro";
import type { ManualSEO } from "@/lib/seo";
import {
  getImageUrl,
  generateDescription,
  getYouTubeVideoId,
  getThumbnailUrl,
} from "@/lib/helpers";
import { buildSEOProps } from "@/lib/seo";

import TourHero from "@/components/tours/TourHero.astro";
import TourTabs from "@/components/tours/TourTabs";
import ContactForm from "@/components/tours/ContactForm.astro";
import BookingForm from "@/components/tours/BookingForm";
import TourCard from "@/components/ui/TourCard.astro";
import LiteYouTube from "@/components/LiteYouTube.astro";

interface MdxFrontmatter {
  title: string;
  description?: string;
  lang: Lang;
  seo?: ManualSEO;
}

interface Props {
  type: "mdx" | "tour" | "page";
  tour?: Tour;
  page?: Page;
  slugMap?: Record<string, string>;
  pageSlugMap?: Record<string, string>;
  mdxComponent?: any;
  mdxFrontmatter?: MdxFrontmatter;
  isRedirect?: boolean;
  redirectTo?: string;
}

export async function getStaticPaths() {
  const paths: Array<{
    params: { lang: string; slug: string };
    props: unknown;
  }> = [];

  // ✅ MDX PAGES - dynamic imports
  const mdxImports = [
    {
      key: "es/codigo-esnna",
      import: () => import("@/content/pages/es/codigo-esnna.mdx"),
    },
    {
      key: "es/libro-reclamaciones",
      import: () => import("@/content/pages/es/libro-reclamaciones.mdx"),
    },
    {
      key: "es/politicas-privacidad",
      import: () => import("@/content/pages/es/politicas-privacidad.mdx"),
    },
    {
      key: "es/nuestros-clientes",
      import: () => import("@/content/pages/es/nuestros-clientes.mdx"),
    },
    {
      key: "es/igualdad-genero",
      import: () => import("@/content/pages/es/igualdad-genero.mdx"),
    },
    {
      key: "es/sobre-nosotros",
      import: () => import("@/content/pages/es/sobre-nosotros.mdx"),
    },
    {
      key: "es/terminos-condiciones",
      import: () => import("@/content/pages/es/terminos-condiciones.mdx"),
    },
    {
      key: "es/metodos-pago",
      import: () => import("@/content/pages/es/metodos-pago.mdx"),
    },
    {
      key: "en/codigo-esnna",
      import: () => import("@/content/pages/en/codigo-esnna.mdx"),
    },
    {
      key: "en/libro-reclamaciones",
      import: () => import("@/content/pages/en/libro-reclamaciones.mdx"),
    },
    {
      key: "en/politicas-privacidad",
      import: () => import("@/content/pages/en/politicas-privacidad.mdx"),
    },
    {
      key: "en/nuestros-clientes",
      import: () => import("@/content/pages/en/nuestros-clientes.mdx"),
    },
    {
      key: "en/igualdad-genero",
      import: () => import("@/content/pages/en/igualdad-genero.mdx"),
    },
    {
      key: "en/sobre-nosotros",
      import: () => import("@/content/pages/en/sobre-nosotros.mdx"),
    },
    {
      key: "en/terminos-condiciones",
      import: () => import("@/content/pages/en/terminos-condiciones.mdx"),
    },
    {
      key: "en/metodos-pago",
      import: () => import("@/content/pages/en/metodos-pago.mdx"),
    },
    {
      key: "en/planea-tu-viaje",
      import: () => import("@/content/pages/en/planea-tu-viaje.mdx"),
    },
    {
      key: "es/planea-tu-viaje",
      import: () => import("@/content/pages/es/planea-tu-viaje.mdx"),
    },
    {
      key: "pt/planea-tu-viaje",
      import: () => import("@/content/pages/pt/planea-tu-viaje.mdx"),
    },
    {
      key: "pt/codigo-esnna",
      import: () => import("@/content/pages/pt/codigo-esnna.mdx"),
    },
    {
      key: "pt/libro-reclamaciones",
      import: () => import("@/content/pages/pt/libro-reclamaciones.mdx"),
    },
    {
      key: "pt/politicas-privacidad",
      import: () => import("@/content/pages/pt/politicas-privacidad.mdx"),
    },
    {
      key: "pt/nuestros-clientes",
      import: () => import("@/content/pages/pt/nuestros-clientes.mdx"),
    },
    {
      key: "pt/igualdad-genero",
      import: () => import("@/content/pages/pt/igualdad-genero.mdx"),
    },
    {
      key: "pt/sobre-nosotros",
      import: () => import("@/content/pages/pt/sobre-nosotros.mdx"),
    },
    {
      key: "pt/terminos-condiciones",
      import: () => import("@/content/pages/pt/terminos-condiciones.mdx"),
    },
    {
      key: "pt/metodos-pago",
      import: () => import("@/content/pages/pt/metodos-pago.mdx"),
    },
  ];

  for (const mdx of mdxImports) {
    const mod = await mdx.import();
    const [lang, slug] = mdx.key.split("/");
    paths.push({
      params: { lang, slug },
      props: {
        type: "mdx",
        mdxComponent: mod,
        mdxFrontmatter: mod.frontmatter || {},
      },
    });
  }

  // ✅ TOURS Y PAGES FROM STRAPI
  const allToursByLang: Record<string, Tour[]> = {};
  const allPagesByLang: Record<string, Page[]> = {};

  for (const lang of LANGS) {
    // El middleware de Strapi ya hace el populate de categories automáticamente
    const tours = await fetchApi<Tour[]>({
      endpoint: "tours",
      wrappedByKey: "data",
      locale: lang,
    });

    const pages = await fetchApi<Page[]>({
      endpoint: "pages",
      wrappedByKey: "data",
      locale: lang,
    });

    allToursByLang[lang] =
      tours && Array.isArray(tours) ? dedupeLocalizedDocuments(tours) : [];
    allPagesByLang[lang] =
      pages && Array.isArray(pages) ? dedupeLocalizedDocuments(pages) : [];
  }

  const slugsByDocId: Record<string, Record<string, string>> = {};
  for (const lang of LANGS) {
    for (const tour of allToursByLang[lang]) {
      if (!slugsByDocId[tour.documentId]) {
        slugsByDocId[tour.documentId] = {};
      }
      slugsByDocId[tour.documentId][lang] = tour.slug;
    }
  }

  for (const lang of LANGS) {
    for (const tour of allToursByLang[lang]) {
      paths.push({
        params: { lang, slug: tour.slug },
        props: {
          type: "tour",
          tour,
          slugMap: slugsByDocId[tour.documentId] ?? {},
        },
      });
    }
  }

  const pageSlugsByDocId: Record<string, Record<string, string>> = {};
  for (const lang of LANGS) {
    for (const page of allPagesByLang[lang]) {
      if (!pageSlugsByDocId[page.documentId]) {
        pageSlugsByDocId[page.documentId] = {};
      }
      pageSlugsByDocId[page.documentId][lang] = page.slug;
      paths.push({
        params: { lang, slug: page.slug },
        props: {
          type: "page",
          page,
          pageSlugMap: pageSlugsByDocId[page.documentId] ?? {},
        },
      });
    }
  }

  // FALLBACK: Redirect para PÁGINAS - cuando alguien usa un slug de otro idioma
  // Para cada página con slugs diferentes entre idiomas, crear redirects para TODAS las combinaciones
  // Ejemplo: pageSlugsByDocId = { docId1: { en: "alternative-treks", es: "treks-alternativos" } }
  // Crea redirects: /es/alternative-treks -> /es/treks-alternativos, /en/treks-alternativos -> /en/alternative-treks

  for (const [docId, slugMap] of Object.entries(pageSlugsByDocId)) {
    const slugs = Object.entries(slugMap) as [string, string][];

    for (const [langA, slugA] of slugs) {
      for (const [langB, slugB] of slugs) {
        if (langA !== langB && slugA !== slugB) {
          // Create redirect: /langA/slugB (lang is A but slug is from B) -> /langA/slugA (lang and slug both correct)
          paths.push({
            params: { lang: langA, slug: slugB },
            props: {
              type: "page",
              isRedirect: true,
              redirectTo: `/${langA}/${slugMap[langA]}`,
              page: allPagesByLang[langA]?.find((p: Page) => p.documentId === docId),
              pageSlugMap: slugMap,
            },
          });
        }
      }
    }
  }

  // FALLBACK: Redirect a DEFAULT_LANG si el tour no existe en el idioma actual
  const defaultLangTours = allToursByLang[DEFAULT_LANG] || [];
  const allTourPathsBySlug: Record<string, string[]> = {};

  // Mapear qué slugs de tours existen en qué idiomas
  for (const path of paths) {
    if (path.props?.type === "tour") {
      const slug = path.params.slug;
      if (!allTourPathsBySlug[slug]) {
        allTourPathsBySlug[slug] = [];
      }
      allTourPathsBySlug[slug].push(path.params.lang);
    }
  }

  // Agregar redirects para slugs de tours que NO existen en otros idiomas pero SÍ en DEFAULT_LANG
  for (const lang of LANGS) {
    if (lang === DEFAULT_LANG) continue;

    const currentLangTours = allToursByLang[lang] || [];
    const currentSlugs = new Set(currentLangTours.map((t: Tour) => t.slug));

    for (const defaultTour of defaultLangTours) {
      if (!currentSlugs.has(defaultTour.slug)) {
        // Verificar que el slug existe en DEFAULT_LANG
        const slugLanguages = allTourPathsBySlug[defaultTour.slug] || [];
        if (slugLanguages.length > 0 && slugLanguages.includes(DEFAULT_LANG)) {
          // Crear redirect 301 al idioma por defecto
          paths.push({
            params: { lang, slug: defaultTour.slug },
            props: {
              type: "tour",
              isRedirect: true,
              redirectTo: `/${DEFAULT_LANG}/${defaultTour.slug}`,
              tour: defaultTour,
              slugMap: slugsByDocId[defaultTour.documentId] ?? {},
            },
          });
        }
      }
    }
  }

  return paths;
}

const {
  type,
  tour,
  page,
  slugMap,
  pageSlugMap,
  mdxComponent,
  mdxFrontmatter,
  isRedirect,
  redirectTo,
} = Astro.props as Props;
const lang = isValidLang(Astro.params.lang) ? Astro.params.lang : DEFAULT_LANG;

// Redirect 301 si la página no existe en este idioma
if (isRedirect && redirectTo) {
  return Astro.redirect(redirectTo, 301);
}

// ====== OBTENER TOUR ACTUAL CON CATEGORÍA ======
// El middleware de Strapi ya hace el populate de categories automáticamente
let tourWithCategory = tour;

if (type === "tour" && tour?.slug) {
  const tourResponse = await fetchApi<Tour[]>({
    endpoint: "tours",
    wrappedByKey: "data",
    locale: lang,
    query: {
      "filters[slug][$eq]": tour.slug,
    },
  });

  if (tourResponse && Array.isArray(tourResponse) && tourResponse.length > 0) {
    tourWithCategory = tourResponse[0];
  }
}

// ====== OBTENER TOURS RELACIONADOS ======
let toursRelated: Tour[] = [];

if (type === "tour") {
  // Obtener la primera categoría del tour actual para filtrar relacionados
  const categorySlug = tourWithCategory?.categories?.[0]?.slug;

  const query: Record<string, string> = {
    "filters[slug][$ne]": tour.slug, // Excluir tour actual
    "pagination[limit]": "3",
  };

  // Si tiene categoría, filtrar por ella
  if (categorySlug) {
    query["filters[categories][slug][$eq]"] = categorySlug;
  }

  const response = await fetchApi<Tour[]>({
    endpoint: "tours",
    wrappedByKey: "data",
    locale: lang,
    query,
  });

  toursRelated = response && Array.isArray(response) ? response : [];
}

// ====== OBTENER TOURS POR CATEGORÍA (PARA PÁGINAS) ======
let toursByCategory: Tour[] = [];

// Tours para páginas (el middleware de tours populatea categories automáticamente)
// Buscamos la categoría específica del destino (no "peru-tours" que es solo para agrupar)
const pageDestinationCategory =
  page?.categories?.find((c: any) => c.slug !== "peru-tours") ??
  (type === "page" && page?.slug
    ? {
        slug: page.slug,
        nombre: page.titulo,
      }
    : undefined);

if (type === "page" && pageDestinationCategory?.slug) {
  const response = await fetchApi<Tour[]>({
    endpoint: "tours",
    wrappedByKey: "data",
    locale: lang,
    query: {
      "filters[categories][slug][$eq]": pageDestinationCategory.slug,
      "pagination[limit]": "6",
    },
  });
  toursByCategory = response && Array.isArray(response) ? response : [];
}

// ====== CHECK INCA TRAIL CATEGORY ======
const isIncaTrail = tourWithCategory?.categories?.some(
  (c: any) =>
    c.slug.includes("inca-trail") ||
    c.slug.includes("camino-inca") ||
    c.slug.includes("trilha-inca"),
);

let seoProps: SEOProps | undefined;

if (type === "mdx" && mdxFrontmatter) {
  seoProps = buildSEOProps({
    seo: mdxFrontmatter.seo,
    fallbackTitle: mdxFrontmatter.title || "Página",
    fallbackDescription: mdxFrontmatter.description || "",
    fallbackImage: "/og-default.jpg",
    type: "website",
    lang: lang,
  });
} else if (type === "tour" && tour) {
  seoProps = buildSEOProps({
    seo: tour.seo,
    fallbackTitle: tour.titulo || "Tour",
    fallbackDescription: generateDescription(tour.content),
    fallbackImage: getImageUrl(tour.imagenDestacada),
    type: "article",
    lang: lang,
    slugMap,
  });
} else if (type === "page" && page) {
  seoProps = buildSEOProps({
    seo: page.seo,
    fallbackTitle: page.titulo || "Página",
    fallbackDescription: generateDescription(page.content),
    fallbackImage: "/og-default.jpg",
    type: "website",
    lang: lang,
    slugMap: pageSlugMap,
  });
}

const pageVideoId =
  type === "page" && page?.video?.videoUrl
    ? getYouTubeVideoId(page.video.videoUrl)
    : null;

const pageVideoThumbnail =
  type === "page" && page?.video?.thumbnail
    ? getThumbnailUrl(page.video.thumbnail)
    : null;

const pageUiCopy = {
  es: {
    eyebrow: "Colección destacada",
    experienceLabel: "Experiencia curada",
    exploreCta: "Ver experiencias",
    toursStat: "experiencias",
  },
  en: {
    eyebrow: "Featured collection",
    experienceLabel: "Curated experience",
    exploreCta: "View experiences",
    toursStat: "experiences",
  },
  pt: {
    eyebrow: "Coleção em destaque",
    experienceLabel: "Experiência curada",
    exploreCta: "Ver experiências",
    toursStat: "experiências",
  },
} as const;

const pageCopy = pageUiCopy[lang] ?? pageUiCopy[DEFAULT_LANG];

const pageStats =
  type === "page" && page
    ? [
        {
          value: toursByCategory.length > 0 ? `${toursByCategory.length}` : "—",
          label: pageCopy.toursStat,
        },
      ]
    : [];
---

{
  type === "mdx" && mdxComponent && (
    <Layout seo={seoProps}>
      <div class="max-w-8xl mx-auto px-4 md:px-6 lg:px-8 py-12">
        <div class="mb-14 md:mb-20 text-center">
          <h1 class="text-3xl md:text-5xl lg:text-6xl font-medium text-gray-900 mb-6 relative inline-block">
            <span class="relative z-10">{mdxFrontmatter.title}</span>
            <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-24 h-3 bg-secondary/30 -z-0 rounded-full blur-sm" />
          </h1>
          <div class="flex items-center justify-center gap-3 mt-4">
            <div class="h-[1px] w-16 bg-gradient-to-r from-transparent to-secondary" />
            <div class="w-12 h-1.5 bg-secondary rounded-full relative">
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 bg-white rounded-full" />
            </div>
            <div class="h-[1px] w-16 bg-gradient-to-l from-transparent to-secondary" />
          </div>
        </div>

        <article class="prose prose-lg max-w-none prose-headings:font-bold prose-headings:text-gray-900 prose-p:text-base prose-p:leading-relaxed prose-p:text-gray-600 prose-a:text-primary hover:prose-a:text-green-800 prose-ul:text-base prose-ol:text-base prose-li:text-gray-600">
          {mdxComponent?.default ? <mdxComponent.default /> : null}
        </article>
      </div>
    </Layout>
  )
}

{
  type === "tour" && tour && (
    <TourLayout seo={seoProps} slugMap={slugMap}>
      <div class="max-w-8xl mx-auto px-4 md:px-6 lg:px-8 pt-6 md:pt-8 pb-12">
        <TourHero tour={tour} lang={lang} badges={tour.badge} />

        <div class="w-full mt-8">
          <TourTabs tour={tour} client:visible>
            <div class="sticky top-24">
              {isIncaTrail ? (
                <BookingForm
                  client:load
                  tourId={tour.documentId}
                  tourName={tour.titulo}
                  basePrice={tour.priceTour}
                  lang={lang}
                />
              ) : (
                <ContactForm tourName={tour.titulo} />
              )}
            </div>
          </TourTabs>
        </div>

        {/* Tours Relacionados */}
        {toursRelated.length > 0 && (
          <section class="w-full mt-16">
            <div class="max-w-8xl mx-auto">
              <div class="text-center mb-10">
                <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6 relative inline-block">
                  <span class="relative z-10">Tours Relacionados</span>
                  <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-24 h-3 bg-secondary/30 -z-0 rounded-full blur-sm" />
                </h2>
                <div class="flex items-center justify-center gap-3 mt-4">
                  <div class="h-[1px] w-16 bg-gradient-to-r from-transparent to-secondary" />
                  <div class="w-12 h-1.5 bg-secondary rounded-full relative">
                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 bg-white rounded-full" />
                  </div>
                  <div class="h-[1px] w-16 bg-gradient-to-l from-transparent to-secondary" />
                </div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {toursRelated.map((relatedTour) => (
                  <TourCard tour={relatedTour} lang={lang} />
                ))}
              </div>
            </div>
          </section>
        )}
      </div>
    </TourLayout>
  )
}

{
  type === "page" && page && (
    <PageContent
      page={page}
      toursByCategory={toursByCategory}
      pageSlugMap={pageSlugMap}
      lang={lang}
      seoProps={seoProps}
    />
  )
}
