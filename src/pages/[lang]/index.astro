---
import Layout from "@/layouts/main.astro";
import fetchApi from "@/lib/strapi";
import type { Home } from "@/interface/home";
import Hero from "@/section/hero.astro";
import About from "@/section/About.astro";
import Certifications from "@/section/Certifications.astro";
import Machupicchu from "@/section/Machupicchu.astro";
import PaquetesPeru from "@/section/PaquetesPeru.astro";
import PeruGuide from "@/section/PeruGuide.astro";
import PaquetesBolivia from "@/section/PaquetesBolivia.astro";
import HomePost from "@/section/HomePost.astro";
import { LANGS, DEFAULT_LANG, isValidLang } from "@/lib/i18n";
import { buildSEOProps } from "@/lib/seo";

export function getStaticPaths() {
  return LANGS.map((lang) => ({
    params: { lang },
  }));
}

const lang = isValidLang(Astro.params.lang) ? Astro.params.lang : DEFAULT_LANG;

const homeData = await fetchApi<Home>({
  endpoint: "home",
  wrappedByKey: "data",
  query: {
    locale: lang,
    "populate[hero][populate]": "*",
    "populate[about][populate]": "*",
    "populate[premios][populate][logo]": "*",
    "populate[sectionMapi][populate][category]": "*",
    "populate[peruPaquetes][populate][category]": "*",
    "populate[boliviaPaquetes][populate][category]": "*",
    "populate[cardPost]": "*",
  },
});

const seoProps = buildSEOProps({
  seo: homeData?.seo,
  fallbackTitle: "Turismo Perú Bolivia - Tours y Paquetes Turísticos",
  fallbackDescription:
    "Organiza tu viaje a Perú y Bolivia con los mejores tours: Machu Picchu, Lago Titicaca, Salar de Uyuni y más. Paquetes turísticos completos.",
  type: "website",
  lang,
});
---

<Layout seo={seoProps}>
  <Hero data={homeData?.hero} lang={lang} />
  <About data={homeData?.about} lang={lang} />
  <Certifications data={homeData?.premios?.premios} lang={lang} />
  <Machupicchu data={homeData?.sectionMapi} lang={lang} />
  <PaquetesPeru data={homeData?.peruPaquetes} lang={lang} />
  <PeruGuide lang={lang} />
  <PaquetesBolivia data={homeData?.boliviaPaquetes} lang={lang} />
  <HomePost data={homeData?.cardPost} lang={lang} />
</Layout>
